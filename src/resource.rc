// Wraith Resource File
// Compile: x86_64-w64-mingw32-windres src/resource.rc -o <OUT_DIR>/resource.o
// (build.rs does this automatically when target_os = windows)

1 ICON "../assets/unlocked-white.ico"
2 ICON "../assets/locked-white.ico"

// Application manifest -- embedded as RT_MANIFEST (ID 1)
1 RT_MANIFEST "../wraith.manifest"

// Settings dialog (id 101 -- must match IDD_SETTINGS in src/settings.rs).
// Style/control values are raw numerics (no #include <windows.h>, matching
// the rest of this file):
//   STYLE 0x80c800c0 = DS_SETFONT(0x40) | DS_MODALFRAME(0x80) |
//                      WS_POPUP(0x80000000) | WS_CAPTION(0x00C00000) |
//                      WS_SYSMENU(0x00080000)
//   EDITTEXT extra style 0x0080 = ES_AUTOHSCROLL. All three EDITTEXT fields
//   (panic key, lock combo, unlock combo) are subclassed at runtime by
//   hotkey_recorder.rs -- they show captured-combo text, not typed input.
//   CONTROL "Lock on start" style 0x50010003 = WS_CHILD(0x40000000) |
//                      WS_VISIBLE(0x10000000) | WS_TABSTOP(0x00010000) |
//                      BS_AUTOCHECKBOX(0x0003) -- CONTROL statements (unlike
//                      the predefined EDITTEXT/LTEXT/PUSHBUTTON statements
//                      above) get no implicit WS_CHILD/WS_VISIBLE, so both
//                      must be spelled out explicitly here.
//   Control IDs 1 = IDOK, 2 = IDCANCEL (Win32 built-ins), 1101 = IDC_PANIC_VK,
//   1102 = IDC_LOCK_COMBO, 1103 = IDC_UNLOCK_COMBO, 1104 = IDC_VALIDATION_ERROR,
//   1105 = IDC_LOCK_ON_START
101 DIALOGEX 0, 0, 200, 160
STYLE 0x80c800c0
CAPTION "Wraith Settings"
FONT 8, "MS Shell Dlg"
BEGIN
    LTEXT           "Panic key:", -1, 10, 10, 120, 8
    EDITTEXT        1101, 10, 22, 120, 14, 0x0080

    LTEXT           "Lock combo:", -1, 10, 44, 120, 8
    EDITTEXT        1102, 10, 56, 120, 14, 0x0080

    LTEXT           "Unlock combo:", -1, 10, 78, 120, 8
    EDITTEXT        1103, 10, 90, 120, 14, 0x0080

    CONTROL         "Lock on start", 1105, "Button", 0x50010003, 10, 108, 100, 12

    LTEXT           "", 1104, 10, 128, 180, 10

    DEFPUSHBUTTON   "OK", 1, 80, 142, 50, 14
    PUSHBUTTON      "Cancel", 2, 134, 142, 50, 14
END

// Version information block (raw numeric values -- no #include <windows.h> needed)
VS_VERSION_INFO VERSIONINFO
FILEVERSION     1,0,0,0
PRODUCTVERSION  1,0,0,0
FILEFLAGSMASK   0x0000003FL
FILEFLAGS       0
FILEOS          0x00040004L
FILETYPE        0x00000001L
FILESUBTYPE     0x00000000L
BEGIN
    BLOCK "StringFileInfo"
    BEGIN
        BLOCK "040904B0"
        BEGIN
            VALUE "CompanyName",      "shadow-dragon-2002"
            VALUE "FileDescription",  "Wraith - Physical Input Blocker"
            VALUE "FileVersion",      "1.0.0"
            VALUE "InternalName",     "wraith"
            VALUE "LegalCopyright",   "GNU General Public License v3.0"
            VALUE "OriginalFilename", "wraith.exe"
            VALUE "ProductName",      "Wraith"
            VALUE "ProductVersion",   "1.0.0"
        END
    END
    BLOCK "VarFileInfo"
    BEGIN
        VALUE "Translation", 0x0409, 0x04B0
    END
END
